# ==============================================================================
# Виконувані файли й артефакти компіляції Go
# ==============================================================================
# Ігноруємо бінарний файл цього проєкту
site-checker

# Загальні правила для скомпільованих файлів і бібліотек
*.exe
*.exe~
*.dll
*.so
*.dylib

# Архіви та можливі локальні каталоги збирання
*.test
*.prof
bin/
.bin/

# ==============================================================================
# Конфігураційні файли та секрети
# ==============================================================================
.env
.env.local
.env.*.local
config.local.json

# Не ігноруємо шаблон середовища (якщо його буде створено в майбутньому)
!.env.example

# ==============================================================================
# Налаштування IDE та редакторів
# ==============================================================================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ==============================================================================
# Системні файли (macOS / Windows)
# ==============================================================================
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# ==============================================================================
# Журнали тестування та профілювання
# ==============================================================================
*.out
*.log
coverage.out
cp.out

# ==============================================================================
# Тимчасові файли Docker BuildKit
# ==============================================================================
.dockerbuild/
